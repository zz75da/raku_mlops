# Data and artifacts
# These are the large files and folders DVC is managing, which should NOT be in Git.
/data/
/artifacts/
/cache/
/feature_cache/

# DVC files are small pointers and MUST be committed to Git.
# The '!' character is used to explicitly re-include them.
!/data/**/*.dvc
!/artifacts/**/*.dvc
!/cache/**/*.dvc
!/feature_cache/**/*.dvc

# DVC's internal directories
.dvc/tmp/
.dvc/cache/

# Airflow
airflow/logs/

# Environment
.env
.env.local
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
logs/
*.log

# Temporary files
tmp/
temp/